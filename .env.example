# ─────────────────────────────────────────────────────────────
# NewsFlow AI — environment variables
# Copy to `.env` and fill in. The app RUNS OUT OF THE BOX with the
# in-memory data layer; the values below are for the production swap.
# ─────────────────────────────────────────────────────────────

# Auth — REQUIRED in production. A dev default is used if unset.
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Durable storage (RECOMMENDED for production / Netlify) ─────
# When BOTH Upstash variables are set, accounts, bookmarks, history,
# interactions and notifications persist in Upstash Redis (serverless-
# safe). When unset, an in-memory store is used (per-instance only).
# Create a free database at https://upstash.com → REST API tab.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional alternative: PostgreSQL via Prisma (schema in prisma/). Not
# required when using Upstash. Matches docker-compose.yml for local dev.
DATABASE_URL="postgresql://newsflow:newsflow@localhost:5432/newsflow?schema=public"

# ── Email (OTP delivery) ──────────────────────────────────────
# RECOMMENDED on Netlify/Vercel: Resend (HTTPS API; SMTP ports are
# usually blocked on serverless). Get a key at https://resend.com.
# When NO provider is set, the app runs in "demo mode" and shows the
# OTP on the verify screen so signup still works.
RESEND_API_KEY=""
EMAIL_FROM="NewsFlow AI <onboarding@resend.dev>"
# Alternative: SMTP (requires nodemailer wiring in src/lib/otp.ts)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ── News sources ──────────────────────────────────────────────
# NEWS_SOURCE: "rss" (default — live BBC + Google News aggregation,
# refreshed every 10 min) or "mock" (deterministic, offline-safe).
NEWS_SOURCE="rss"
# Optional NewsAPI.org key (takes priority over RSS when set).
NEWSAPI_KEY=""
# Optional custom feeds: "url|category|source, url|category|source"
RSS_FEEDS=""

# LLM for AI summaries / takeaways. When unset, an extractive
# summarizer runs locally (no key needed).
ANTHROPIC_API_KEY=""
AI_MODEL="claude-opus-4-8"
